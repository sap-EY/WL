# =============================================================================
# Wockhardt WhatsApp Bot — environment template
# Copy to `.env` (NEVER commit `.env`) and fill in the secrets.
# =============================================================================

# === App ===
APP_NAME=wabot
APP_ENV=local                       # local|dev|staging|prod
APP_LOG_LEVEL=INFO
APP_LOG_JSON=true
APP_HTTP_PORT=8000
APP_REQUEST_TIMEOUT_SECONDS=30
APP_FEATURE_FLAG_DRY_RUN_OUTBOUND=false

# === DB (Azure PostgreSQL Flexible Server) =================================
# We pass components, not a URL, so the password is never embedded in a string.
# The DSN is assembled at startup in src/wabot/infra/config.py.
DB_HOST=docbotdatabase.postgres.database.azure.com
DB_PORT=5432
DB_USER=drbot_admin
DB_PASSWORD=
DB_NAME=postgres
DB_SCHEMA=wabot
DB_SSL_MODE=require
DB_POOL_SIZE=20
DB_POOL_MAX_OVERFLOW=20
DB_STATEMENT_TIMEOUT_MS=15000

# === Redis ===
REDIS_URL=redis://localhost:6379/0
REDIS_LOCK_TTL_SECONDS=30
REDIS_DEDUPE_TTL_SECONDS=600

# === Interakt ===
INTERAKT_BASE_URL=https://api.interakt.ai
INTERAKT_API_KEY=
INTERAKT_TIMEOUT_CONNECT_SECONDS=5
INTERAKT_TIMEOUT_READ_SECONDS=10
INTERAKT_RATE_LIMIT_RPS=80
INTERAKT_WEBHOOK_PATH_SECRET=change-me
INTERAKT_ALLOWED_CIDRS=0.0.0.0/0

# === Templates / catalog ===
TEMPLATE_DOCTOR_WELCOME_CONSENT=doctor_welcome_consent_v1
TEMPLATE_HOTLINE=hotline_v1
TEMPLATE_LOCALE=en
SUPPORT_CONTACT_VALUE=+91-XXXXXXXXXX

# === GenAI ===
GENAI_BASE_URL=
GENAI_API_KEY=
GENAI_TIMEOUT_CONNECT_SECONDS=2
GENAI_TIMEOUT_READ_SECONDS=20
GENAI_CIRCUIT_FAIL_THRESHOLD=5
GENAI_CIRCUIT_WINDOW_SECONDS=60

# === Broker ===
BROKER_BACKEND=redis_streams        # redis_streams|azure_servicebus
BROKER_INBOUND_STREAM=wabot.inbound
BROKER_INBOUND_GROUP=wabot.inbound.workers
BROKER_DLQ_STREAM=wabot.inbound.dlq
SERVICEBUS_CONNECTION_STRING=
SERVICEBUS_QUEUE_INBOUND=wabot-inbound
